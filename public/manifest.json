{
  "name": "MiniPlay",
  "short_name": "MiniPlay",
  "description": "A minimalistic offline media player PWA",
  "start_url": "/MiniPlay/",
  "display": "standalone",
  "display_override": ["window-controls-overlay"],
  "orientation": "any",
  "background_color": "#000000",
  "theme_color": "#000000",
  "icons": [
    {
      "src": "/MiniPlay/icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any maskable"
    }
  ],
  "file_handlers": [
    {
      "action": "/MiniPlay/",
      "accept": {
        "audio/*": [".mp3", ".wav", ".ogg", ".flac", ".aac", ".m4a", ".wma", ".webm", ".opus"],
        "video/*": [".mp4", ".webm", ".ogg", ".mov"]
      }
    }
  ]
}
